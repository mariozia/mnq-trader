# Set to "mock" for paper trading with simulated data/LLM, or "live" for real APIs
TRADING_MODE=mock

# Anthropic (required when TRADING_MODE=live)
ANTHROPIC_API_KEY=

# TopstepX (required when TRADING_MODE=live)
TOPSTEPX_API_KEY=
TOPSTEPX_USERNAME=

# Robinhood GEX (optional, falls back to mock GEX)
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=

# Discord alerts for blind recon mismatches
DISCORD_WEBHOOK_URL=
