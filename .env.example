# ──────────────────────────────────────────────────────────────────────────
# MNQ Trader configuration
# Copy this file to ".env" and fill in only what you need for your mode.
#
#   cp .env.example .env
#
# WHAT EACH MODE NEEDS:
#   mock  (default) -> nothing. Runs the simulator + rule-based mock "LLM".
#                      Use this to test the full system, backtest, and tune.
#   live            -> ANTHROPIC_API_KEY (real Claude decisions) and, to place
#                      real orders, the TopstepX broker adapter implemented +
#                      its credentials below. Without a broker key it still
#                      makes real LLM decisions but cannot execute.
# ──────────────────────────────────────────────────────────────────────────

# "mock" = fully simulated (no keys). "live" = real Claude (+ broker if wired).
TRADING_MODE=mock

# ── Anthropic Claude (needed only when TRADING_MODE=live) ───────────────────
# Get a key at https://console.anthropic.com/  ->  API Keys
ANTHROPIC_API_KEY=

# ── TopstepX / ProjectX broker (needed only to place real/sim orders) ───────
# The broker adapter is a stub today (see execution/broker.py: TopstepXBroker).
# Fill these in once that adapter is implemented.
TOPSTEPX_API_KEY=
TOPSTEPX_USERNAME=

# ── Robinhood GEX feed (optional; falls back to mock GEX if blank) ───────────
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=

# ── Discord alerts for blind-recon mismatches (optional) ────────────────────
DISCORD_WEBHOOK_URL=
